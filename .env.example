# ─── Racing Portfolio — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in real values.
# Variables prefixed with VITE_ are exposed to the browser bundle.

# Optional: URL of your backend schedule scraper endpoint.
# If set, the Schedule component fetches live race data from here.
# Leave blank to use the static SCHEDULE array in src/data/config.ts
VITE_SCHEDULE_API_URL=
